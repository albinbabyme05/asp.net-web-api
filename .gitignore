## Ignore Visual Studio temporary files, build results,
## and files generated by common editors and tools.

############################
# User-specific files
############################
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

############################
# Build folders
############################
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
build/
bld/
[Bb]in/
[Oo]bj/
out/

############################
# Visual Studio
############################
.vs/

############################
# Rider / JetBrains
############################
.idea/
*.sln.iml

############################
# VS Code
############################
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

############################
# Logs
############################
*.log
logs/

############################
# ASP.NET / app settings
############################
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

############################
# Environment files
############################
.env
.env.*
!.env.example

############################
# IIS Express
############################
iisexpress/

############################
# NuGet
############################
*.nupkg
*.snupkg
packages/
!packages/build/
.nuget/
*.nuget.props
*.nuget.targets

############################
# Publish output
############################
publish/
wwwroot/dist/
wwwroot/build/

############################
# Test results / coverage
############################
TestResults/
*.coverage
*.coveragexml
coverage/
coverage-report/

############################
# Entity Framework / database local files
############################
*.mdf
*.ldf
*.db
*.sqlite
*.sqlite3

############################
# OS generated files
############################
.DS_Store
Thumbs.db
desktop.ini

############################
# Resharper
############################
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

############################
# NCrunch
############################
*.ncrunch*
.*crunch*.local.xml
nCrunchTemp_*

############################
# DotCover
############################
*.dotCover

############################
# BenchmarkDotNet
############################
BenchmarkDotNet.Artifacts/

############################
# Azure
############################
*.azurePubxml

############################
# Docker
############################
docker-compose.override.yml

############################
# Node modules (if frontend or Swagger custom UI assets exist)
############################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

############################
# Temporary files
############################
*.tmp
*.temp
*.cache

############################
# Generated files
############################
Generated/
appsettings.Development.json

.vs
bin
obj


/.vs
/bin
/obj